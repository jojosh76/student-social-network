# Copy this file to backend/.env on the VPS or configure the same values as Jenkins credentials.
# Do not commit real production secrets.

POSTGRES_DB=campus_link
POSTGRES_USER=campus_prod
POSTGRES_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-a-long-random-jwt-secret

# Internal Docker network database URL. Keep host as "postgres" when using docker compose.
DATABASE_URL=postgres://campus_prod:replace-with-a-long-random-password@postgres:5432/campus_link

# Public URLs used by generated file links and CORS.
PUBLIC_BASE_URL=https://your-domain.example/files
FRONTEND_URL=https://your-domain.example
